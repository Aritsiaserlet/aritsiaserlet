rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Works Collection (Read-Only)
    match /works/{workId} {
      allow read: if true;
      allow write: if false; 
    }

    // 2. Users Collection
    match /users/{userId} {
      allow read: if true;
      
      // Helper functions
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }
      
      function onlyAllowedFields() {
        let incomingKeys = request.resource.data.keys();
        let allowedKeys = ['displayName', 'photoURL', 'highScore', 'bestCombo', 'gamesPlayed', 'totalScore', 'lastPlayed', 'lastLogin', 'createdAt'];
        return incomingKeys.hasOnly(allowedKeys);
      }
      
      function validScoreIncrease() {
        let oldData = resource.data;
        let newData = request.resource.data;
        let validHigh = !("highScore" in newData) || !("highScore" in oldData) || newData.highScore >= oldData.highScore;
        let validTotal = !("totalScore" in newData) || !("totalScore" in oldData) || newData.totalScore >= oldData.totalScore;
        let validGames = !("gamesPlayed" in newData) || !("gamesPlayed" in oldData) || newData.gamesPlayed >= oldData.gamesPlayed;
        return validHigh && validTotal && validGames;
      }

      allow create: if isOwner() && onlyAllowedFields();
      allow update: if isOwner() && onlyAllowedFields() && validScoreIncrease();

      // 3. Likes Subcollection
      match /likes/{workId} {
        allow read: if true;
        allow write: if isOwner();
      }
    }
  }
}
